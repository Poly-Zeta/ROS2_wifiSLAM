<?xml version="1.0"?>
<robot name="my_robot">

<!--  <link name="base_footprint"/> -->
  <link name="base_link"/>

<!--  <joint name="base_footprint_to_base_link" type="fixed"> -->
<!--    <parent link="base_footprint"/> -->
<!--    <child link="base_link"/> -->
<!--    <origin xyz="0 0 0.085" rpy="0 0 0"/> -->
<!--  </joint> -->

  <link name="laser_link"/>
  <joint name="base_to_laser" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <origin xyz="0.03 -0.01 0.11" rpy="0 0 -1.5708"/>
  </joint>

  <link name="imu_link"/>
  <joint name="base_to_imu" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="-0.035 -0.015 0.085" rpy="0 0 0"/>
  </joint>

  <link name="camera_link"/>
  <joint name="base_to_camera" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.115 0 0.085" rpy="0 0 0"/>
  </joint>

  <link name="d435i_camera_link"/>

  <joint name="camera_to_d435i" type="fixed">
    <parent link="camera_link"/>
    <child link="d435i_camera_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

</robot>
